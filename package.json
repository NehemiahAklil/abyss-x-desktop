{
  "name": "abyss-x-desktop",
  "version": "0.1.1",
  "main": "index.js",
  "description": "Unofficial desktop app for Nothing & CMF earbuds — Electron wrapper for ear (web)",
  "author": {
    "name": "Nehemiah Aklil",
    "email": "nehemiahaklil@gmail.com"
  },
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/NehemiahAklil/nothing-x-desktop",
  "repository": {
    "type": "git",
    "url": "https://github.com/NehemiahAklil/nothing-x-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/NehemiahAklil/nothing-x-desktop/issues"
  },
  "keywords": [
    "nothing",
    "cmf",
    "earbuds",
    "bluetooth",
    "electron"
  ],
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux AppImage",
    "build:deb": "electron-builder --linux deb",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder -mwl"
  },
  "build": {
    "appId": "xyz.bttl.earweb.unofficial",
    "productName": "Abyss X",
    "copyright": "Copyright © 2024 Nehemiah Aklil. Frontend © RapidZapper & Bendix (GPLv3)",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "index.js",
      "preload.js",
      "res/**/*"
    ],
    "linux": {
      "icon": "build/icons",
      "category": "Audio",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "desktop": {
        "entry": {
          "Name": "Abyss X",
          "Comment": "Unofficial desktop app for Nothing / CMF earbuds",
          "Categories": "Audio;AudioVideo;Utility;"
        }
      }
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "icon": "build/icons/512x512.png",
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^37.2.5",
    "electron-builder": "^26.0.12"
  }
}
